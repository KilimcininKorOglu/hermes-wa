# .env.example
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/whatsapp-2121?sslmode=disable
APP_DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/custom-hermeswa?sslmode=disable
JWT_SECRET=YOUR_JWT_SECRET
PORT=2121
BASEURL=127.0.0.1
CORS_ALLOW_ORIGINS=http://localhost:8080,http://localhost:3000
HERMESWA_ENABLE_WEBSOCKET_INCOMING_MSG=false
HERMESWA_ENABLE_WEBHOOK=false
HERMESWA_TYPING_DELAY_MIN=1
HERMESWA_TYPING_DELAY_MAX=3
ALLOW_9_DIGIT_PHONE_NUMBER=false # If true, allows 9-digit numbers without validation

JWT_ACCESS_TOKEN_EXPIRY=1h  # Access token valid for 1 hour
JWT_REFRESH_TOKEN_EXPIRY=168h # Refresh token valid for 7 days (168 hours)
MAX_REFRESH_TOKENS_PER_USER=10 # Maximum 10 refresh tokens per user

# Resource Limits
MAX_INSTANCES_PER_USER=10         # Maximum WhatsApp instances per non-admin user
OUTBOX_MAX_DAILY_PER_USER=10000   # Maximum outbox messages per user per day

# Rate Limiting
RATE_LIMIT_PER_SECOND=10
RATE_LIMIT_BURST=10
RATE_LIMIT_WINDOW_MINUTES=3

# File Upload Limits (in MB)
MAX_FILE_SIZE_IMAGE_MB=5
MAX_FILE_SIZE_VIDEO_MB=16
MAX_FILE_SIZE_AUDIO_MB=16
MAX_FILE_SIZE_DOCUMENT_MB=100

# Avatar Upload Configuration
UPLOAD_DIR=./uploads
MAX_AVATAR_SIZE_MB=1
MAX_AVATAR_SIZE_KB=500
ALLOWED_AVATAR_TYPES=jpg,jpeg,png,webp
AVATAR_OUTPUT_FORMAT=webp
AVATAR_MAX_DIMENSION=1024
AVATAR_MIN_DIMENSION=100

# ==========================================
# WARMING SYSTEM CONFIGURATION
# ==========================================
# BOT_VS_BOT Warming Worker
WARMING_WORKER_ENABLED=false
WARMING_WORKER_INTERVAL_SECONDS=5

# HUMAN_VS_BOT Auto-Reply
WARMING_AUTO_REPLY_ENABLED=false
WARMING_AUTO_REPLY_COOLDOWN=60  # Minimum seconds between auto-replies per room (prevents spam)

# ==========================================
# AI CONFIGURATION (Google Gemini - FREE)
# ==========================================
AI_ENABLED=false
AI_DEFAULT_PROVIDER=gemini  # gemini (FREE) or openai (paid)

# Google Gemini (Recommended - FREE Tier)
GEMINI_API_KEY=API_KEY
GEMINI_DEFAULT_MODEL=gemini-flash-latest

# AI Settings
AI_CONVERSATION_HISTORY_LIMIT=10  # Last N messages for context
AI_DEFAULT_TEMPERATURE=0.7
AI_DEFAULT_MAX_TOKENS=150

# Default Reply Delays for HUMAN_VS_BOT (in seconds)
DEFAULT_REPLY_DELAY_MIN=10
DEFAULT_REPLY_DELAY_MAX=60

# ==========================================
# STANDALONE OUTBOX WORKER CONFIGURATION
# ==========================================
# Database URL where the 'outbox' table resides.
# If left empty, the system will automatically use APP_DATABASE_URL as target (default).
# Supports mysql://user:pass@tcp(host:port)/db or postgres://... format
OUTBOX_DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/hermeswa_outbox?sslmode=disable
# Base URL of your Hermeswa API
OUTBOX_API_BASEURL=http://localhost:2121
# Credentials for the worker to login
OUTBOX_API_USER=admin1
OUTBOX_API_PASS=123123123