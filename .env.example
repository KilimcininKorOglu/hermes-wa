# .env.example — Copy to .env and fill in your values.

# ==========================================
# DATABASE
# ==========================================
# whatsmeow session database
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/whatsmeow?sslmode=disable
# Application database
APP_DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/charon?sslmode=disable

# ==========================================
# AUTH
# ==========================================
JWT_SECRET=YOUR_JWT_SECRET
# Access token valid for 1 hour
JWT_ACCESS_TOKEN_EXPIRY=1h
# Refresh token valid for 7 days (168 hours)
JWT_REFRESH_TOKEN_EXPIRY=168h
# Maximum number of active refresh tokens per user
MAX_REFRESH_TOKENS_PER_USER=10

# ==========================================
# SERVER
# ==========================================
PORT=2121
BASEURL=127.0.0.1
CORS_ALLOW_ORIGINS=http://localhost:8080,http://localhost:3000

# ==========================================
# PHONE NUMBER
# ==========================================
# Country code for phone number formatting and auto-conversion (digits only, no +).
# e.g. 90 = Turkey, 62 = Indonesia, 1 = USA. Leave empty to require full E.164 format.
# When set: "05XXXXXXXXX" and "5XXXXXXXXX" are automatically converted to "{cc}XXXXXXXXX".
PHONE_COUNTRY_CODE=90

# ==========================================
# FEATURES
# ==========================================
CHARON_ENABLE_WEBSOCKET_INCOMING_MSG=false
CHARON_ENABLE_WEBHOOK=false
# If true, allows 9-digit phone numbers without country-code validation
ALLOW_9_DIGIT_PHONE_NUMBER=false
CHARON_TYPING_DELAY_MIN=1
CHARON_TYPING_DELAY_MAX=3

# ==========================================
# RESOURCE LIMITS
# ==========================================
# Maximum WhatsApp instances per non-admin user
MAX_INSTANCES_PER_USER=10
# Maximum outbox messages per user per day
OUTBOX_MAX_DAILY_PER_USER=10000

# ==========================================
# RATE LIMITING
# ==========================================
RATE_LIMIT_PER_SECOND=10
RATE_LIMIT_BURST=10
RATE_LIMIT_WINDOW_MINUTES=3

# ==========================================
# FILE UPLOAD LIMITS (in MB)
# ==========================================
MAX_FILE_SIZE_IMAGE_MB=5
MAX_FILE_SIZE_VIDEO_MB=16
MAX_FILE_SIZE_AUDIO_MB=16
MAX_FILE_SIZE_DOCUMENT_MB=100

# ==========================================
# AVATAR UPLOAD CONFIGURATION
# ==========================================
UPLOAD_DIR=./uploads
MAX_AVATAR_SIZE_MB=1
MAX_AVATAR_SIZE_KB=500
ALLOWED_AVATAR_TYPES=jpg,jpeg,png,webp
AVATAR_OUTPUT_FORMAT=webp
AVATAR_MAX_DIMENSION=1024
AVATAR_MIN_DIMENSION=100

# ==========================================
# WARMING SYSTEM
# ==========================================
# BOT_VS_BOT warming worker
WARMING_WORKER_ENABLED=false
WARMING_WORKER_INTERVAL_SECONDS=5

# HUMAN_VS_BOT auto-reply
WARMING_AUTO_REPLY_ENABLED=false
# Minimum seconds between auto-replies per room (prevents spam)
WARMING_AUTO_REPLY_COOLDOWN=60

# ==========================================
# AI CONFIGURATION (Google Gemini)
# ==========================================
AI_ENABLED=false
# Supported provider: gemini
AI_DEFAULT_PROVIDER=gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_DEFAULT_MODEL=gemini-flash-latest
# Number of previous messages to include as context
AI_CONVERSATION_HISTORY_LIMIT=10
AI_DEFAULT_TEMPERATURE=0.7
AI_DEFAULT_MAX_TOKENS=150

# Default reply delays for HUMAN_VS_BOT mode (in seconds)
DEFAULT_REPLY_DELAY_MIN=10
DEFAULT_REPLY_DELAY_MAX=60

# ==========================================
# STANDALONE OUTBOX WORKER
# ==========================================
# Database URL where the outbox table resides.
# If left empty, APP_DATABASE_URL is used automatically.
OUTBOX_DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/charon?sslmode=disable
# Base URL of the Charon API the worker should connect to
OUTBOX_API_BASEURL=http://localhost:2121
# Worker login credentials (must match a user in the application)
OUTBOX_API_USER=YOUR_OUTBOX_USER
OUTBOX_API_PASS=YOUR_OUTBOX_PASS
